#!/usr/bin/env bash
# gh pr-summarise: Generate and apply a PR description using GitHub Models.
#
# Required tools:
#   gh    - GitHub CLI (https://cli.github.com), authenticated via `gh auth login`
#   curl  - HTTP client, used to call the GitHub Models API
#   jq    - JSON processor (https://jqlang.org)

set -euo pipefail

# ── Version ───────────────────────────────────────────────────────────────────
VERSION="0.1.0"

# ── Defaults ──────────────────────────────────────────────────────────────────
MODEL="${PR_SUMMARISE_MODEL:-openai/gpt-4.1}"
MAX_DIFF_CHARS="${PR_SUMMARISE_MAX_DIFF_CHARS:-28000}"
ENDPOINT="${PR_SUMMARISE_ENDPOINT:-https://models.github.ai/inference/chat/completions}"
# For org attribution, set:
# export PR_SUMMARISE_ENDPOINT="https://models.github.ai/orgs/<ORG>/inference/chat/completions"

YES=false
FORCE=false
PROMPT_FILE="${PR_SUMMARISE_PROMPT_FILE:-}"
PR=""
REPO_ARGS=()

# ── Usage ─────────────────────────────────────────────────────────────────────
usage() {
  cat <<EOF
Usage: gh pr-summarise [PR] [options]

Generate a PR description from the diff using GitHub Models and optionally
apply it to the pull request.

PR can be a number (123) or a full GitHub URL
(https://github.com/owner/repo/pull/123).
If omitted, uses the open PR for the current branch.

Options:
  -m, --model MODEL             Model to use (default: $MODEL)
                                Run 'gh models list' to see available models.
  -n, --max-diff-chars N        Diff truncation limit in characters (default: $MAX_DIFF_CHARS)
  -y, --yes                     Apply without asking for confirmation
  -f, --force                   Generate even if a human-written description exists
  -p, --prompt-file PATH        Path to a file containing a custom prompt.
                                The diff is always appended after the prompt text.
                                Overrides PR_SUMMARISE_PROMPT_FILE.
  -h, --help                    Show this help
  -v, --version                 Show version

Environment variables:
  PR_SUMMARISE_ENDPOINT         Override the GitHub Models API endpoint.
                                Useful for org-attributed usage:
                                https://models.github.ai/orgs/<ORG>/inference/chat/completions
  PR_SUMMARISE_PROMPT_FILE      Path to a file containing a custom prompt.
                                Overridden by --prompt-file.
EOF
}

# ── Argument parsing ──────────────────────────────────────────────────────────
while [[ $# -gt 0 ]]; do
  case "$1" in
    -h|--help)
      usage; exit 0 ;;
    -v|--version)
      echo "gh pr-summarise $VERSION"; exit 0 ;;
    -m|--model)
      MODEL="$2"; shift 2 ;;
    -n|--max-diff-chars)
      if ! [[ "$2" =~ ^[0-9]+$ ]] || [[ "$2" -eq 0 ]]; then
        echo "Error: --max-diff-chars must be a positive integer, got: $2" >&2; exit 1
      fi
      MAX_DIFF_CHARS="$2"; shift 2 ;;
    -y|--yes)
      YES=true; shift ;;
    -f|--force)
      FORCE=true; shift ;;
    -p|--prompt-file)
      PROMPT_FILE="$2"; shift 2 ;;
    -*)
      echo "Error: unknown option: $1" >&2; echo; usage >&2; exit 1 ;;
    *)
      if [[ -n "$PR" ]]; then
        echo "Error: unexpected argument: $1" >&2; echo; usage >&2; exit 1
      fi
      PR="$1"; shift ;;
  esac
done

# ── Validate prompt file ───────────────────────────────────────────────────────
if [[ -n "$PROMPT_FILE" && ! -r "$PROMPT_FILE" ]]; then
  echo "Error: prompt file not found or not readable: $PROMPT_FILE" >&2
  exit 1
fi

# ── Resolve PR number ─────────────────────────────────────────────────────────
if [[ -z "$PR" ]]; then
  if ! PR=$(gh pr view --json number -q '.number' 2>/dev/null); then
    echo "Error: no PR given and no open PR found for the current branch." >&2
    exit 1
  fi
elif [[ "$PR" =~ ^https?://github\.com/([^/]+/[^/]+)/pull/([0-9]+) ]]; then
  REPO_ARGS=("--repo" "${BASH_REMATCH[1]}")
  PR="${BASH_REMATCH[2]}"
fi

# ── Fetch existing PR description ─────────────────────────────────────────────
EXISTING_BODY=$(gh pr view "${REPO_ARGS[@]}" "$PR" --json body -q '.body // ""')
MARKER="<!-- pr-summarise -->"

# Extract a leading tracker URL to preserve across generation and regeneration.
# Strip a possible trailing \r so the pattern works with CRLF line endings.
PREFIX=""
FIRST_LINE="${EXISTING_BODY%%$'\n'*}"
FIRST_LINE="${FIRST_LINE%$'\r'}"
if [[ "$FIRST_LINE" =~ ^https?://[^[:space:]]+$ ]]; then
  PREFIX="$FIRST_LINE"
fi

# A body is link-only when the first line is a URL and everything that follows
# (ignoring whitespace) is empty.  Stripping ALL whitespace before the check
# was wrong: it concatenated URL + body text into one non-space string that
# always matched the URL pattern.
BODY_REST=""
[[ "$EXISTING_BODY" == *$'\n'* ]] && BODY_REST="${EXISTING_BODY#*$'\n'}"
BODY_REST_TRIMMED="${BODY_REST//[$'\t\r\n ']/}"

if [[ "$FORCE" == false && -n "$EXISTING_BODY" && "$EXISTING_BODY" != *"$MARKER"* ]]; then
  if [[ -z "$PREFIX" || -n "$BODY_REST_TRIMMED" ]]; then
    echo "PR #$PR already has a human-written description. Skipping." >&2
    echo "(Use --force to generate anyway.)" >&2
    echo ""
    echo "$EXISTING_BODY"
    exit 0
  fi
fi

# ── Fetch diff ────────────────────────────────────────────────────────────────
echo "Fetching diff for PR #$PR..."
FULL_DIFF=$(gh pr diff "${REPO_ARGS[@]}" "$PR" --patch)
DIFF="${FULL_DIFF:0:$MAX_DIFF_CHARS}"

if [[ -z "$DIFF" ]]; then
  echo "Error: no diff found for PR #$PR." >&2
  exit 1
fi

# ── Resolve prompt ─────────────────────────────────────────────────────────────
if [[ -n "$PROMPT_FILE" ]]; then
  PROMPT_TEXT="$(cat "$PROMPT_FILE")"
else
  PROMPT_TEXT="Write a concise GitHub PR description in Markdown for this diff.
Format:
1) One short summary paragraph.
2) A \"## Changes\" section with bullet points.
3) A \"## Notes for reviewers\" section (optional, only if useful).
Output only raw Markdown text. Do not wrap the output in a code fence or backtick block."
fi

# ── Call GitHub Models ────────────────────────────────────────────────────────
echo "Generating summary via GitHub Models ($MODEL)..."
RESPONSE=$(curl -sS -L "$ENDPOINT" \
  -H "Authorization: Bearer $(gh auth token)" \
  -H "Accept: application/vnd.github+json" \
  -H "X-GitHub-Api-Version: 2022-11-28" \
  -H "Content-Type: application/json" \
  -d "$(jq -n \
    --arg model  "$MODEL" \
    --arg prompt "$PROMPT_TEXT" \
    --arg diff   "$DIFF" \
    '{
      model: $model,
      temperature: 0.2,
      max_tokens: 500,
      messages: [{
        role: "user",
        content: $prompt + "\n\n" + $diff
      }]
    }')")

SUMMARY=$(echo "$RESPONSE" | jq -r '.choices[0].message.content' 2>/dev/null) || SUMMARY=""

if [[ -z "$SUMMARY" || "$SUMMARY" == "null" ]]; then
  echo "Error: no summary returned by GitHub Models. Raw response:" >&2
  echo "$RESPONSE" >&2
  exit 1
fi

# ── Compose final body ────────────────────────────────────────────────────────
if [[ -n "$PREFIX" ]]; then
  FINAL_BODY="${PREFIX}"$'\n\n'"${SUMMARY}"$'\n\n'"${MARKER}"
else
  FINAL_BODY="${SUMMARY}"$'\n\n'"${MARKER}"
fi

# ── Review and confirm ────────────────────────────────────────────────────────
echo ""
echo "──── Generated description ────────────────────────────────────────────────"
echo "$FINAL_BODY"
echo "───────────────────────────────────────────────────────────────────────────"
echo ""

if [[ "$YES" == true ]]; then
  confirm="y"
else
  read -r -p "Apply this description to PR #$PR? [y/N] " confirm
fi

if [[ "$confirm" =~ ^[Yy]$ ]]; then
  gh pr edit "${REPO_ARGS[@]}" "$PR" --body "$FINAL_BODY"
  PR_URL=$(gh pr view "${REPO_ARGS[@]}" "$PR" --json url -q '.url')
  echo "PR #$PR description updated: $PR_URL"
else
  echo "Aborted. No changes made."
fi
